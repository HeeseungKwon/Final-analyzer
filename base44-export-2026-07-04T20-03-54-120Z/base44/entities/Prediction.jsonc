{
  "name": "Prediction",
  "type": "object",
  "properties": {
    "game_pk": {
      "type": "number"
    },
    "game_date": {
      "type": "string"
    },
    "player_id": {
      "type": "number"
    },
    "player_name": {
      "type": "string"
    },
    "team_id": {
      "type": "number"
    },
    "team_name": {
      "type": "string"
    },
    "player_type": {
      "type": "string",
      "enum": [
        "hitter",
        "pitcher"
      ]
    },
    "market": {
      "type": "string",
      "enum": [
        "hit_1",
        "hit_2",
        "hrr",
        "hrr_2",
        "hrr_3",
        "total_bases",
        "home_run",
        "strikeouts"
      ]
    },
    "confidence": {
      "type": "number"
    },
    "projection": {
      "type": "number"
    },
    "confidence_score": {
      "type": "number"
    },
    "projection_score": {
      "type": "number"
    },
    "market_edge": {
      "type": "number"
    },
    "expected_hits": {
      "type": "number"
    },
    "expected_total_bases": {
      "type": "number"
    },
    "expected_home_runs": {
      "type": "number"
    },
    "expected_runs": {
      "type": "number"
    },
    "expected_rbi": {
      "type": "number"
    },
    "expected_hrr": {
      "type": "number"
    },
    "floor": {
      "type": "number"
    },
    "ceiling": {
      "type": "number"
    },
    "trigger_text": {
      "type": "string"
    },
    "trigger_strength": {
      "type": "number"
    },
    "features": {
      "type": "string"
    },
    "data_quality": {
      "type": "string",
      "enum": [
        "ok",
        "partial",
        "missing"
      ]
    },
    "recommended": {
      "type": "boolean"
    },
    "rec_score": {
      "type": "number"
    },
    "player_rating": {
      "type": "string"
    },
    "player_stars": {
      "type": "number"
    },
    "verdict": {
      "type": "string"
    },
    "verdict_note": {
      "type": "string"
    },
    "graded": {
      "type": "boolean",
      "default": false
    },
    "hit": {
      "type": "boolean"
    }
  },
  "required": [
    "game_pk",
    "game_date",
    "player_name",
    "market"
  ]
}
